rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for validation
    function isValidReview(review) {
      return review.keys().hasAll([
        'locationName', 'address', 'cleanliness', 'smell', 
        'comfort', 'soapSupplies', 'stallSecurity', 'comments', 'createdAt'
      ]) &&
      review.locationName is string && review.locationName.size() >= 2 &&
      review.address is string && review.address.size() >= 5 &&
      review.cleanliness is int && review.cleanliness >= 1 && review.cleanliness <= 5 &&
      review.smell is int && review.smell >= 1 && review.smell <= 5 &&
      review.comfort is int && review.comfort >= 1 && review.comfort <= 5 &&
      review.soapSupplies is int && review.soapSupplies >= 1 && review.soapSupplies <= 5 &&
      review.stallSecurity is int && review.stallSecurity >= 1 && review.stallSecurity <= 5 &&
      review.comments is string && review.comments.size() >= 10 && review.comments.size() <= 1000;
    }
    
    function isValidNomination(nomination) {
      return nomination.keys().hasAll([
        'businessName', 'businessLocation', 'reason', 'createdAt'
      ]) &&
      nomination.businessName is string && nomination.businessName.size() >= 2 &&
      nomination.businessLocation is string && nomination.businessLocation.size() >= 5 &&
      nomination.reason is string && nomination.reason.size() >= 20 && nomination.reason.size() <= 1000;
    }
    
    function isValidSocialReview(social) {
      return social.keys().hasAll([
        'locationName', 'platform', 'postLink', 'createdAt'
      ]) &&
      social.locationName is string && social.locationName.size() >= 2 &&
      social.platform in ['tiktok', 'instagram', 'youtube_shorts', 'twitter_x'] &&
      social.postLink is string && social.postLink.matches('https?://.*');
    }
    
    // Reviews Collection - Public read, authenticated create
    match /reviews/{reviewId} {
      allow read: if true; // Public can read all reviews
      
      allow create: if request.auth != null &&
                    isValidReview(request.resource.data) &&
                    request.resource.data.createdAt == request.time &&
                    request.resource.data.userId == request.auth.uid;
      
      allow update: if request.auth != null &&
                    (request.auth.uid == resource.data.userId || 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') &&
                    request.resource.data.userId == resource.data.userId && // Can't change ownership
                    request.resource.data.createdAt == resource.data.createdAt; // Can't change created time
      
      allow delete: if request.auth != null &&
                    (request.auth.uid == resource.data.userId || 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Nominations Collection - Public read, anyone can create
    match /nominations/{nominationId} {
      allow read: if true; // Public can read nominations
      
      allow create: if isValidNomination(request.resource.data) &&
                    request.resource.data.createdAt == request.time;
      
      allow update, delete: if request.auth != null &&
                            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Social Reviews Collection - Public read, authenticated create
    match /socialReviews/{socialReviewId} {
      allow read: if true; // Public can read social reviews
      
      allow create: if request.auth != null &&
                    isValidSocialReview(request.resource.data) &&
                    request.resource.data.createdAt == request.time &&
                    request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if request.auth != null &&
                            (request.auth.uid == resource.data.userId || 
                             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Users Collection - Private user data
    match /users/{userId} {
      allow read: if request.auth != null && 
                  (request.auth.uid == userId || 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      allow create: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.data.createdAt == request.time;
      
      allow update: if request.auth != null && 
                    request.auth.uid == userId &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'createdAt']);
      
      allow delete: if request.auth != null && 
                    (request.auth.uid == userId || 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Admin-only Collections
    match /adminStats/{document=**} {
      allow read, write: if request.auth != null &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /reports/{reportId} {
      allow read, write: if request.auth != null &&
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      allow create: if request.auth != null; // Any authenticated user can report content
    }
    
    // Public metadata/stats - Read-only for public, write for system
    match /metadata/{document=**} {
      allow read: if true;
      allow write: if false; // Only backend/cloud functions can write
    }
    
    // Deny all other accesses by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}